{
  // Press F5 to launch a second VS Code window (the Extension Development Host) with the Fuse
  // extension loaded from source. The preLaunchTask bundles it first; use the "watch" task for
  // an incremental rebuild loop.
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Fuse Extension",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "--disable-extensions"
      ],
      "outFiles": [
        "${workspaceFolder}/dist/**/*.js"
      ],
      "preLaunchTask": "npm: build"
    }
  ]
}
