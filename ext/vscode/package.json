{
  "name": "fuse-vscode",
  "displayName": "Fuse",
  "description": "Warm Fuse engine in VS Code: index status, token hotspots, dependency graph, scoping, and secret diagnostics. The human-facing twin of the Fuse MCP server.",
  "version": "4.0.0",
  "publisher": "litenova",
  "license": "Apache-2.0",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "workspaceContains:**/*.csproj",
    "workspaceContains:**/*.sln",
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "fuse",
          "title": "Fuse",
          "icon": "media/fuse.svg"
        }
      ]
    },
    "views": {
      "fuse": [
        {
          "id": "fuse.indexStatus",
          "name": "Index"
        },
        {
          "id": "fuse.hotspots",
          "name": "Token Hotspots"
        },
        {
          "id": "fuse.scopeResult",
          "name": "Scope Result"
        },
        {
          "id": "fuse.explainer",
          "name": "Explain"
        },
        {
          "id": "fuse.sessions",
          "name": "Agent Sessions"
        }
      ]
    },
    "commands": [
      {
        "command": "fuse.index",
        "title": "Fuse: Index Workspace"
      },
      {
        "command": "fuse.restartHost",
        "title": "Fuse: Restart Host"
      },
      {
        "command": "fuse.search",
        "title": "Fuse: Search"
      },
      {
        "command": "fuse.focusHere",
        "title": "Fuse: Focus Here"
      },
      {
        "command": "fuse.changesSince",
        "title": "Fuse: Changes Since Branch"
      },
      {
        "command": "fuse.showGraph",
        "title": "Fuse: Show Dependency Graph"
      },
      {
        "command": "fuse.explainScope",
        "title": "Fuse: Explain Scope"
      },
      {
        "command": "fuse.refreshSessions",
        "title": "Fuse: Refresh Agent Sessions",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "fuse.refreshSessions",
          "when": "view == fuse.sessions",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "fuse.focusHere",
          "group": "fuse"
        }
      ],
      "explorer/context": [
        {
          "command": "fuse.focusHere",
          "group": "fuse"
        }
      ]
    },
    "configuration": {
      "title": "Fuse",
      "properties": {
        "fuse.autoIndexThreshold": {
          "type": "number",
          "default": 2000,
          "description": "Auto-index a workspace with at most this many files on open; above it, index on demand."
        },
        "fuse.host.path": {
          "type": "string",
          "default": "",
          "description": "Path to the fuse host executable. Empty uses the bundled or PATH-resolved 'fuse'."
        },
        "fuse.showTokenLens": {
          "type": "boolean",
          "default": false,
          "description": "Show a CodeLens at the top of each file with its Fuse token cost and graph centrality."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "pretest": "npm run build && tsc -p ./ --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "typecheck": "tsc -p ./ --noEmit && tsc -p tsconfig.webview.json --noEmit",
    "test:contract": "node --test ./test/contract.test.mjs ./test/sessionModel.test.mjs",
    "test": "node ./dist/test/runTest.js",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/cytoscape": "^3.21.9",
    "@types/node": "^22.0.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.24.0",
    "eslint": "^8.57.0",
    "typescript": "^5.6.0"
  },
  "dependencies": {
    "cytoscape": "^3.34.0",
    "vscode-jsonrpc": "^8.2.0"
  }
}
