<Project Sdk="Microsoft.NET.Sdk">
    <PropertyGroup>
        <TargetFramework>net10.0</TargetFramework>
        <ImplicitUsings>enable</ImplicitUsings>
        <Nullable>enable</Nullable>
        <UseFileScopedNamespaces>true</UseFileScopedNamespaces>
    </PropertyGroup>
    <ItemGroup>
        <InternalsVisibleTo Include="Fuse.Semantics.Tests"/>
    </ItemGroup>
    <ItemGroup>
        <!-- C1: the environment-remediation knowledge base ships as data (embedded JSON), loaded by
             RemediationKnowledgeBase.LoadDefault, so the troubleshooting docs can be generated from it. -->
        <EmbeddedResource Include="Remediation/remediation-kb.json"/>
    </ItemGroup>
    <ItemGroup>
        <PackageReference Include="Microsoft.Extensions.Logging.Abstractions"/>
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp"/>
        <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Workspaces"/>
        <PackageReference Include="Microsoft.CodeAnalysis.Workspaces.MSBuild"/>
        <PackageReference Include="Microsoft.Build.Locator"/>
    </ItemGroup>
    <ItemGroup>
        <ProjectReference Include="..\Fuse.Collection\Fuse.Collection.csproj"/>
        <ProjectReference Include="..\Fuse.Indexing\Fuse.Indexing.csproj"/>
    </ItemGroup>
</Project>
