<file path="src/SampleShop.Web/Program.cs">
var builder = WebApplication.CreateBuilder(args);
var app = builder.Build();
app.MapGet("/health", () => Results.Ok("ok"));
app.MapPost("/hooks/stripe", () => Results.Ok());
app.Run();
</file>
<file path="src/SampleShop.Core/Services/OrderService.cs">
namespace SampleShop.Core.Services;
public class OrderService
{
private readonly PaymentService _payments = new();
public void PlaceOrder(int orderId)
{
_payments.ProcessPayment(99.99m);
}
}
