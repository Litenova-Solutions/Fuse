<?xml version="1.0" encoding="utf-8"?>
<!-- Central Package Management with two distinct remote package sources and no packageSourceMapping: the exact
     shape that triggers NU1507 on restore. NU1507 counts remote (http) sources, so both are http here. With the
     csproj escalating NU1507 to an error, a bare build fails on it, so the fuse up tier-1 probe deterministically
     detects the blocker and classifies it to the overlay remedy. The overlay adds the source mapping (clearing
     NU1507) and is passed by configfile, never written into the repo. A full build-success flip additionally
     needs both feeds reachable; the second feed here is a placeholder, so the flip is bounded by network
     reachability (see the C1 progress log), while the detect-and-clear path is deterministic and offline-safe. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="contoso" value="https://contoso.example/nuget/v3/index.json" />
  </packageSources>
</configuration>
