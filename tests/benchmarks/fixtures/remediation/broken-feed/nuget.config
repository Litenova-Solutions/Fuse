<?xml version="1.0" encoding="utf-8"?>
<!-- Central Package Management with two package sources and no packageSourceMapping: the exact shape that
     triggers NU1507 on restore. `fuse up` generates an overlay NuGet.config supplying the source mapping
     (passed via --configfile, never written into the repo) and re-attempts the load. Synthetic C1 fixture. -->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="dupe" value="https://api.nuget.org/v3/index.json" />
  </packageSources>
</configuration>
